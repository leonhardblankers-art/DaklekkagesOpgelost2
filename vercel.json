{
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/pages/:path*",
      "destination": "/:path*",
      "permanent": true
    },
    {
      "source": "/blog/:path*",
      "destination": "/kennisbank/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/contact",
      "destination": "/pages/contact/index.html"
    },
    {
      "source": "/contact/",
      "destination": "/pages/contact/index.html"
    },
    {
      "source": "/contact/:path*",
      "destination": "/pages/contact/:path*/index.html"
    },
    {
      "source": "/diensten",
      "destination": "/pages/diensten/index.html"
    },
    {
      "source": "/diensten/",
      "destination": "/pages/diensten/index.html"
    },
    {
      "source": "/diensten/:slug",
      "destination": "/pages/diensten/:slug/index.html"
    },
    {
      "source": "/diensten/:slug/",
      "destination": "/pages/diensten/:slug/index.html"
    },
    {
      "source": "/diensten/:path*",
      "destination": "/pages/diensten/:path*/index.html"
    },
    {
      "source": "/lekkages",
      "destination": "/pages/lekkages/index.html"
    },
    {
      "source": "/lekkages/",
      "destination": "/pages/lekkages/index.html"
    },
    {
      "source": "/lekkages/:slug",
      "destination": "/pages/lekkages/:slug/index.html"
    },
    {
      "source": "/lekkages/:slug/",
      "destination": "/pages/lekkages/:slug/index.html"
    },
    {
      "source": "/lekkages/:path*",
      "destination": "/pages/lekkages/:path*/index.html"
    },
    {
      "source": "/kennisbank",
      "destination": "/pages/kennisbank/index.html"
    },
    {
      "source": "/kennisbank/",
      "destination": "/pages/kennisbank/index.html"
    },
    {
      "source": "/kennisbank/:path*",
      "destination": "/pages/kennisbank/:path*/index.html"
    },
    {
      "source": "/over-ons",
      "destination": "/pages/over-ons/index.html"
    },
    {
      "source": "/over-ons/",
      "destination": "/pages/over-ons/index.html"
    },
    {
      "source": "/over-ons/:slug",
      "destination": "/pages/over-ons/:slug/index.html"
    },
    {
      "source": "/over-ons/:slug/",
      "destination": "/pages/over-ons/:slug/index.html"
    },
    {
      "source": "/over-ons/:path*",
      "destination": "/pages/over-ons/:path*/index.html"
    },
    {
      "source": "/legal",
      "destination": "/pages/legal/index.html"
    },
    {
      "source": "/legal/",
      "destination": "/pages/legal/index.html"
    },
    {
      "source": "/legal/:path*",
      "destination": "/pages/legal/:path*/index.html"
    }
  ]
}
