{
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/pages/:path*",
      "destination": "/:path*",
      "permanent": true
    },
    {
      "source": "/blog/:path*",
      "destination": "/kennisbank/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/contact/:path*",
      "destination": "/pages/contact/:path*"
    },
    {
      "source": "/diensten/:path*",
      "destination": "/pages/diensten/:path*"
    },
    {
      "source": "/lekkages/:path*",
      "destination": "/pages/lekkages/:path*"
    },
    {
      "source": "/kennisbank/:path*",
      "destination": "/pages/kennisbank/:path*"
    },
    {
      "source": "/over-ons/:path*",
      "destination": "/pages/over-ons/:path*"
    },
    {
      "source": "/legal/:path*",
      "destination": "/pages/legal/:path*"
    }
  ]
}
