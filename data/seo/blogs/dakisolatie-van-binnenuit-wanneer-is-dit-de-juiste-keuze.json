          "mainEntity": [
            {
              "@type": "Question",
              "name": "Is dakisolatie van binnenuit altijd goedkoper dan van buitenaf?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Vaak wel, omdat de dakbedekking niet verwijderd hoeft te worden. Extra kosten kunnen ontstaan door afwerking, dampremming en ventilatie."
              }
            },
            {
              "@type": "Question",
              "name": "Kan ik zelf dakisolatie van binnenuit aanbrengen?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Kleine delen zijn soms zelf te isoleren, maar fouten in dampremming en aansluiting kunnen later vochtproblemen veroorzaken."
              }
            },
            {
              "@type": "Question",
              "name": "Hoeveel ruimte verlies ik door binnenisolatie?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Afhankelijk van materiaal en dakconstructie kan het ruimteverlies variëren van enkele centimeters tot meer dan tien centimeter."
              }
            },
            {
              "@type": "Question",
              "name": "Is binnenisolatie geschikt bij een plat dak?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Bij platte daken brengt binnenisolatie extra risico’s op condens met zich mee en is isolatie aan de buitenzijde vaak geschikter."
              }
            },
            {
              "@type": "Question",
              "name": "Heeft dakisolatie van binnenuit invloed op geluid?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Ja, vooral bij hellende daken kan het geluid van regen en omgevingsgeluid merkbaar afnemen, afhankelijk van het isolatiemateriaal."
