        "mainEntity": [
          {
            "@type": "Question",
            "name": "Is dakisolatie van binnenuit altijd goedkoper dan van buitenaf ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "In veel gevallen wel, omdat de dakbedekking niet verwijderd hoeft te worden. Toch kunnen extra kosten ontstaan door afwerking, dampremmende lagen en ventilatiemaatregelen."
            }
          },
          {
            "@type": "Question",
            "name": "Kan ik zelf dakisolatie van binnenuit aanbrengen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Kleine delen zijn soms zelf te isoleren, maar fouten in dampremming of aansluiting kunnen later grote problemen veroorzaken. Bouwfysisch inzicht is hierbij belangrijk."
            }
          },
          {
            "@type": "Question",
            "name": "Hoeveel ruimte verlies ik door binnenisolatie ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dit verschilt per materiaal en dakconstructie, maar enkele centimeters tot meer dan tien centimeter is geen uitzondering."
            }
          },
          {
            "@type": "Question",
            "name": "Is binnenisolatie geschikt bij een plat dak ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Bij platte daken brengt binnenisolatie extra risico’s op condens met zich mee en is het vaak minder geschikt dan isolatie aan de buitenzijde."
            }
          },
          {
            "@type": "Question",
            "name": "Heeft dakisolatie van binnenuit invloed op geluid ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja, vooral bij hellende daken kan het geluid van regen en omgevingsgeluid merkbaar afnemen, afhankelijk van het gebruikte materiaal."
            }
          }
