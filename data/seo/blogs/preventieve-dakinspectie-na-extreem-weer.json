        "mainEntity": [
          {
            "@type": "Question",
            "name": "Is een inspectie nodig als er geen lekkage is ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet per se, maar het ontbreken van lekkage betekent niet dat er geen schade is. Veel problemen worden pas later zichtbaar, afhankelijk van weersverloop en materiaalgedrag."
            }
          },
          {
            "@type": "Question",
            "name": "Hoe snel na extreem weer heeft inspectie zin ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat verschilt per situatie. Soms is direct controleren zinvol, soms juist na een paar weken, wanneer verborgen vocht zich heeft verplaatst of materialen tot rust zijn gekomen."
            }
          },
          {
            "@type": "Question",
            "name": "Kan schade vanzelf herstellen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Sommige verschijnselen, zoals tijdelijk vocht in isolatie, kunnen uitdrogen. Andere processen, zoals veroudering of scheurvorming, zijn onomkeerbaar. Zonder inspectie blijft dat onderscheid vaak onduidelijk."
            }
          }
        ]
