        "mainEntity": [
          {
            "@type": "Question",
            "name": "Is een reparatie altijd tijdelijk ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee, bij een relatief jong dak kan een reparatie jarenlang probleemloos meegaan. Het hangt sterk af van de algemene staat van het dak."
            }
          },
          {
            "@type": "Question",
            "name": "Hoe vaak mag een dak gerepareerd worden ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Er is geen vast aantal, maar als reparaties elkaar snel opvolgen, is dat meestal een signaal dat het dak zijn grens nadert."
            }
          },
          {
            "@type": "Question",
            "name": "Is vervanging altijd duurder dan repareren ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Op korte termijn wel, maar op langere termijn kan vervanging juist voordeliger zijn doordat vervolgschade en herhaalde kosten worden voorkomen."
            }
          }
