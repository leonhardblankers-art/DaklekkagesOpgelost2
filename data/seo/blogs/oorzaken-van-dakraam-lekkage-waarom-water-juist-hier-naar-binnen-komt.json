        "mainEntity": [
          {
            "@type": "Question",
            "name": "Kan een relatief nieuw dakraam al lekken ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Hoewel de kans kleiner is, kunnen montagekeuzes, extreme weersomstandigheden of problemen in de omliggende dakbedekking ook bij nieuwere dakramen tot lekkage leiden."
            }
          },
          {
            "@type": "Question",
            "name": "Is lekkage altijd zichtbaar direct na regen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. Water kan zich eerst ophopen in de dakconstructie en pas later zichtbaar worden, soms zelfs dagen na een regenperiode."
            }
          },
          {
            "@type": "Question",
            "name": "Spelen weersomstandigheden echt zo’n grote rol ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Windrichting, slagregen en langdurige neerslag beïnvloeden hoe water zich rond een dakraam gedraagt. Daardoor kunnen klachten onregelmatig optreden."
            }
          },
          {
            "@type": "Question",
            "name": "Kan ik aan de binnenkant zien waar het probleem zit ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Zelden. De plek waar vocht zichtbaar wordt, is vaak niet de plek waar het water naar binnen komt. Dat maakt oorzaak en gevolg lastig te scheiden."
            }
          }
        ]
