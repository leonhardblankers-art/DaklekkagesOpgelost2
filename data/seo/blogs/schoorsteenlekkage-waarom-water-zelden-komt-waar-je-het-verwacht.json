        "mainEntity": [
          {
            "@type": "Question",
            "name": "Hoe weet ik of een lekkage echt van de schoorsteen komt ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat is vaak lastig vast te stellen zonder inspectie. De locatie van de vochtplek komt niet altijd overeen met de plek waar het water binnendringt."
            }
          },
          {
            "@type": "Question",
            "name": "Kan een schoorsteenlekkage vanzelf verdwijnen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Soms lijkt een lekkage tijdelijk weg te zijn bij droog weer, maar de onderliggende oorzaak blijft meestal aanwezig."
            }
          },
          {
            "@type": "Question",
            "name": "Is elke vochtplek rond de schoorsteen een lekkage ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee, vocht kan ook ontstaan door condensatie, vooral bij ongebruikte schoorstenen of slechte ventilatie."
            }
          },
          {
            "@type": "Question",
            "name": "Waarom lekt het vooral bij harde wind ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Bij slagregen wordt water onder druk tegen de schoorsteen geblazen, waardoor zwakke plekken sneller water doorlaten."
            }
          },
          {
            "@type": "Question",
            "name": "Kan één kleine scheur echt zoveel schade veroorzaken ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja, water kan zich via kleine openingen verspreiden en over een groot oppervlak schade aanrichten."
            }
          }
        ]
