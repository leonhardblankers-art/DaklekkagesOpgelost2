        },
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Hoe weet ik of mijn afvoer goed werkt ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Als er na een regenbui geen plassen blijven staan, is dat een goed teken. Blijft water liggen, dan is er een probleem."
            }
          },
          {
            "@type": "Question",
            "name": "Kan een verstopte afvoer lekkage veroorzaken ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Stilstaand water vergroot de druk op naden en scheuren, waardoor lekkages sneller ontstaan."
            }
          },
          {
            "@type": "Question",
            "name": "Hoe vaak moet ik mijn afvoeren schoonmaken ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Minstens één keer per jaar, en vaker als er veel bladeren of vuil op het dak komt."
            }
          },
          {
            "@type": "Question",
            "name": "Is één afvoer genoeg voor een plat dak ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat hangt af van de grootte en vorm van het dak. Sommige daken hebben meerdere afvoeren nodig."
            }
          },
          {
            "@type": "Question",
            "name": "Kan slechte afvoer ook de isolatie aantasten ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Water dat onder de dakbedekking komt, trekt vaak de isolatie in en verliest daar zijn warmte-isolerende werking"
            }
          }
        ]
