            "@type": "Question",
            "name": "Hoe vaak moet een dakraam worden gecontroleerd ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Er bestaat geen vaste regel. Periodiek controleren, bijvoorbeeld in combinatie met ander dakonderhoud, helpt om veranderingen tijdig te signaleren."
            }
          },
          {
            "@type": "Question",
            "name": "Is schoonmaken al voldoende als onderhoud ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Schoonmaken is belangrijk, maar niet voldoende. Het voorkomt blokkades, maar zegt niets over de staat van afdichtingen of aansluitingen."
            }
          },
          {
            "@type": "Question",
            "name": "Kan goed onderhoud lekkage volledig voorkomen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. Onderhoud verkleint de kans en beperkt risico’s, maar sluit problemen door veroudering of extreme omstandigheden niet uit."
            }
          },
          {
            "@type": "Question",
            "name": "Heeft onderhoud zin bij oudere dakramen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja, zolang het dakraam technisch functioneert. Onderhoud kan de levensduur verlengen en problemen beheersbaar houden."
            }
          }
