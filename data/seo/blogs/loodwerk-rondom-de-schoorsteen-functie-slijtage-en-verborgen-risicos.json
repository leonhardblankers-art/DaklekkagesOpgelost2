        "mainEntity": [
          {
            "@type": "Question",
            "name": "Hoe lang gaat loodwerk rondom een schoorsteen mee ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "De levensduur varieert sterk, maar ligt vaak tussen de 25 en 40 jaar, afhankelijk van belasting, montage en onderhoud."
            }
          },
          {
            "@type": "Question",
            "name": "Kan loodwerk plaatselijk worden hersteld ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "In sommige gevallen wel, bijvoorbeeld bij loszittend lood. Bij scheuren of veroudering is vervanging meestal verstandiger."
            }
          },
          {
            "@type": "Question",
            "name": "Zijn lekkages door lood altijd direct zichtbaar ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee, water kan zich langs de constructie verspreiden voordat het binnenshuis zichtbaar wordt."
            }
          },
          {
            "@type": "Question",
            "name": "Is lood altijd nodig rondom een schoorsteen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Bij traditionele schoorstenen wel. Alternatieve materialen bestaan, maar hebben andere eigenschappen en aandachtspunten."
            }
          },
          {
            "@type": "Question",
            "name": "Kan slecht loodwerk invloed hebben op het metselwerk ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja, binnendringend vocht kan het metselwerk aantasten en vorstschade veroorzaken."
            }
          }
