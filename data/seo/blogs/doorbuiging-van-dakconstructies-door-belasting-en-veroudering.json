          "mainEntity": [
            {
              "@type": "Question",
              "name": "Wat veroorzaakt doorbuiging van een dakconstructie?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Doorbuiging ontstaat meestal door langdurige belasting, veroudering van materialen, vochtproblemen of constructieve verzwakking. Ook eerdere lekkages kunnen bijdragen aan verminderde draagkracht."
              }
            },
            {
              "@type": "Question",
              "name": "Is doorbuiging van een dak gevaarlijk?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Ja, ernstige doorbuiging kan wijzen op structurele problemen in de dakconstructie. Wanneer dit niet tijdig wordt aangepakt, kan dit leiden tot verdere schade of zelfs instortingsgevaar."
              }
            },
            {
              "@type": "Question",
              "name": "Hoe herken je beginnende constructieve schade aan een dak?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Signalen zijn onder meer zichtbare verzakkingen, scheuren in muren of plafonds, klemmende deuren of ramen en terugkerende lekkages. Een professionele inspectie geeft duidelijkheid over de oorzaak."
              }
            }
          ]
