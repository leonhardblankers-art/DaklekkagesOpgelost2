        "mainEntity": [
          {
            "@type": "Question",
            "name": "Hoe weet ik of mijn dak nog te repareren is ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat hangt af van de staat van het onderdak en het houtwerk. Zichtbare schade vertelt maar een deel van het verhaal."
            }
          },
          {
            "@type": "Question",
            "name": "Is een oude lekkage altijd een teken dat renovatie nodig is ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet per se. Eén lekkage kan lokaal zijn. Het wordt pas zorgelijk als problemen blijven terugkomen of zich verspreiden."
            }
          },
          {
            "@type": "Question",
            "name": "Waarom zie ik vaak binnen schade terwijl de pannen er goed uitzien ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Omdat water vaak onder de pannen blijft zitten en daar langzaam zijn werk doet. De zichtbare laag is niet de waterkerende laag."
            }
          },
          {
            "@type": "Question",
            "name": "Kan een inspectie echt verschil maken ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Alleen door onder de pannen en bij de aansluitingen te kijken, wordt duidelijk of het dak nog samenhang heeft."
            }
          }
