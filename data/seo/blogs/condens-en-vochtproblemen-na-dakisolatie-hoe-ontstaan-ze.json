        "mainEntity": [
          {
            "@type": "Question",
            "name": "Ontstaat condens altijd na dakisolatie ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee, bij een juiste dakopbouw hoeft condens geen probleem te zijn. Het ontstaat vooral wanneer dampremming of ventilatie tekortschiet."
            }
          },
          {
            "@type": "Question",
            "name": "Kan schimmel vanzelf verdwijnen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Schimmel kan oppervlakkig verdwijnen, maar de oorzaak blijft bestaan zolang het vochtprobleem niet wordt opgelost."
            }
          },
          {
            "@type": "Question",
            "name": "Is ventilatie nodig bij een goed geïsoleerd dak ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja, isolatie vermindert warmteverlies maar voert geen vocht af. Ventilatie blijft noodzakelijk."
            }
          },
          {
            "@type": "Question",
            "name": "Zijn vochtproblemen altijd direct zichtbaar ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee, vaak ontstaan ze langzaam en worden pas laat opgemerkt."
            }
          },
          {
            "@type": "Question",
            "name": "Is buitenisolatie veiliger tegen condens ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Technisch gezien wel, omdat de constructie warmer blijft en het dauwpunt buiten het hout ligt."
            }
          }
