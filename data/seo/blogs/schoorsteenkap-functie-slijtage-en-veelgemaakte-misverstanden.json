        "mainEntity": [
          {
            "@type": "Question",
            "name": "Is een schoorsteenkap altijd noodzakelijk ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet elke schoorsteen heeft een kap nodig. De noodzaak hangt af van de functie van de schoorsteen en de manier waarop rook of lucht wordt afgevoerd."
            }
          },
          {
            "@type": "Question",
            "name": "Kan een schoorsteenkap een lekkage oplossen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Een kap kan regeninslag beperken, maar lost geen structurele problemen op zoals slecht voegwerk of beschadigde aansluitingen."
            }
          },
          {
            "@type": "Question",
            "name": "Hoe herken ik slijtage aan een schoorsteenkap ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Slijtage uit zich vaak in roest, scheuren, losse bevestigingen of een kap die scheef staat."
            }
          },
          {
            "@type": "Question",
            "name": "Kan een kap rookproblemen veroorzaken ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja, een ongeschikte of verkeerd geplaatste kap kan de trek verstoren en rookterugslag veroorzaken."
            }
          },
          {
            "@type": "Question",
            "name": "Hoe lang gaat een schoorsteenkap mee ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "De levensduur verschilt per materiaal en omstandigheden, maar ook een kap vraagt periodieke controle en onderhoud."
            }
          }
        ]
