        "mainEntity": [
          {
            "@type": "Question",
            "name": "Waarom komt een daklekkage pas na jaren terug ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Omdat schade zich vaak intern ontwikkelt en pas zichtbaar wordt wanneer materialen hun grens bereiken of de waterbelasting toeneemt."
            }
          },
          {
            "@type": "Question",
            "name": "Kan een dak jarenlang lekvrij lijken terwijl er toch een probleem is ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Vocht kan lange tijd opgesloten blijven in isolatie of constructie zonder direct zichtbare schade."
            }
          },
          {
            "@type": "Question",
            "name": "Hebben weersomstandigheden invloed op vertraagde lekkages ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Zeker. Extreme regen, wind of dooi kunnen bestaande zwakke plekken plots blootleggen."
            }
          },
          {
            "@type": "Question",
            "name": "Zijn oude reparaties altijd de oorzaak van vertraagde lekkages ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet altijd, maar ze spelen vaak een rol doordat ze de waterloop of vochtopbouw beïnvloeden."
            }
          },
          {
            "@type": "Question",
            "name": "Hoe voorkom ik dat een lekkage pas na jaren wordt ontdekt ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Door periodieke inspectie en tijdig onderzoek bij kleine signalen kan verborgen schade eerder worden opgespoord."
