        {
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "Hoe weet ik zeker dat de lekkage via de schoorsteen komt?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Dat is niet altijd direct vast te stellen. De locatie van vochtplekken, het moment waarop ze ontstaan en de staat van de schoorsteen geven vaak samen aanwijzingen. Soms is inspectie nodig om zekerheid te krijgen."
              }
            },
            {
              "@type": "Question",
              "name": "Kan een kleine scheur in de schoorsteen echt lekkage veroorzaken?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Ja. Zelfs kleine scheurtjes of poreus voegwerk kunnen bij langdurige regen voldoende water doorlaten om binnen schade te veroorzaken."
              }
            },
            {
              "@type": "Question",
              "name": "Komt schoorsteenlekkage vooral voor bij oude woningen?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Oudere woningen lopen meer risico door verouderde materialen, maar ook bij relatief recente huizen kunnen lekkages ontstaan door constructiefouten of slijtage van aansluitingen."
              }
            },
            {
              "@type": "Question",
              "name": "Is lekkage via de schoorsteen altijd zichtbaar in huis?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Nee. Water kan zich langere tijd onzichtbaar verplaatsen via constructiedelen voordat het zichtbaar wordt als vochtplek of schade."
              }
            },
            {
              "@type": "Question",
              "name": "Lost het plaatsen van een schoorsteenkap lekkage altijd op?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Niet altijd. Een kap kan regeninloop beperken, maar lost geen problemen op met voegwerk, loodslabben of scheuren in het metselwerk."
              }
            }
          ]
