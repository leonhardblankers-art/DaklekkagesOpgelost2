        "mainEntity": [
          {
            "@type": "Question",
            "name": "Kan een kleine daklekkage vanzelf stoppen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "In de praktijk zelden. Soms lijkt een lekkage tijdelijk te verdwijnen door droog weer, maar de onderliggende oorzaak blijft meestal aanwezig."
            }
          },
          {
            "@type": "Question",
            "name": "Hoe snel ontstaat er schade bij een lekkage ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat verschilt per situatie. Bij sommige daken ontstaat binnen enkele weken schade aan isolatie, terwijl houtrot vaak pas na langere tijd zichtbaar wordt."
            }
          },
          {
            "@type": "Question",
            "name": "Is alle schade direct zichtbaar in huis ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. Veel schade blijft lange tijd verborgen in de dakconstructie of isolatie, waardoor het probleem wordt onderschat."
            }
          },
          {
            "@type": "Question",
            "name": "Maakt het type dak verschil ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Platte daken en daken met complexe details zijn gevoeliger voor langdurige vochtproblemen omdat water minder snel wordt afgevoerd."
            }
          }
        ]
