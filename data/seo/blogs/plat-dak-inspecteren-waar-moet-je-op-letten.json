        "mainEntity": [
          {
            "@type": "Question",
            "name": "Hoe vaak moet een plat dak worden geïnspecteerd ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Idealiter minstens één keer per jaar en na zware stormen of langdurige regen."
            }
          },
          {
            "@type": "Question",
            "name": "Kan ik mijn dak zelf inspecteren ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Je kunt zichtbare vervuiling en schade bekijken, maar verborgen problemen onder de toplaag zie je meestal niet."
            }
          },
          {
            "@type": "Question",
            "name": "Wat kost een dakinspectie ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat hangt af van het type dak en de bereikbaarheid, maar de kosten zijn meestal beperkt in verhouding tot de schade die je ermee voorkomt."
            }
          },
          {
            "@type": "Question",
            "name": "Wat gebeurt er als ik te laat inspecteer ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dan worden kleine problemen vaak pas ontdekt wanneer ze al grote gevolgen hebben voor isolatie en binnenafwerking."
            }
          },
          {
            "@type": "Question",
            "name": "Is een inspectie alleen zinvol bij lekkage ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. Juist voordat er lekkage is, kan een inspectie problemen vroegtijdig signaleren."
            }
          }
