          {
            "@type": "Question",
            "name": "Hoe weet ik of verkleuring normaal is of schade betekent ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Verkleuring is meestal normaal zolang het gelijkmatig verloopt en geen materiaalverlies veroorzaakt."
            }
          },
          {
            "@type": "Question",
            "name": "Is mos op dakpannen altijd een probleem ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet altijd. Mos wijst wel op langdurige vochtbelasting, wat de veroudering kan versnellen."
            }
          },
          {
            "@type": "Question",
            "name": "Kan schade ontstaan zonder zichtbare lekkage ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Vocht kan zich ophopen in onderliggende lagen voordat het binnenshuis zichtbaar wordt."
            }
          },
          {
            "@type": "Question",
            "name": "Moet een oud dak vaker gecontroleerd worden ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Oudere daken hebben vaker baat bij periodieke controle omdat veroudering en schade dichter bij elkaar liggen."
            }
          },
          {
            "@type": "Question",
            "name": "Is schade altijd lokaal te herstellen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat hangt af van de omvang en duur van het probleem. Tijdige signalering vergroot de kans op beperkt herstel."
