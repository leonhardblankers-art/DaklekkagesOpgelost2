          "mainEntity": [
            {
              "@type": "Question",
              "name": "Wanneer is een vochtplek reden tot actie?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Als de plek groter wordt, terugkomt bij regen/wind, of gepaard gaat met een muffe geur, afbladderen, zachte ondergrond of schimmel. Bij actieve druppels is direct handelen verstandig."
              }
            },
            {
              "@type": "Question",
              "name": "Hoe lang kun je verantwoord monitoren?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Alleen als de plek klein en stabiel is én je duidelijke stopmomenten afspreekt (bijv. “bij groei”, “na 2 buien”, “bij nieuwe geur”). Monitoren zonder stopmoment wordt snel uitstel."
              }
            },
            {
              "@type": "Question",
              "name": "Kan een lekkage vanzelf stoppen?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Soms lijkt dat zo, bijvoorbeeld door droger weer of omdat vuil een naad tijdelijk “dicht” houdt. Dat betekent niet dat het probleem opgelost is. Intermitterende lekkages komen vaak terug."
              }
            },
            {
              "@type": "Question",
              "name": "Wat zegt schimmelgeur zonder zichtbare plek?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Geur kan wijzen op verborgen vocht (bijvoorbeeld in isolatie of achter plaatmateriaal). Zeker als het terugkomt na nat weer, is verder onderzoek verstandig."
              }
            },
            {
              "@type": "Question",
              "name": "Waarom zie je soms pas laat schade aan het dak?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Water kan onder lagen of langs constructiedelen lopen en pas later zichtbaar worden. Ook kan isolatie eerst vocht opnemen voordat het aan de binnenkant zichtbaar wordt."
              }
            }
          ]
        },
