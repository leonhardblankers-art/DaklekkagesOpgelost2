          },
          {
            "@type": "Question",
            "name": "Kan een schoorsteen later alsnog volledig worden verwijderd ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat kan, maar het betekent wel extra werk en kosten. Het is daarom verstandig om deze afweging vooraf goed te maken."
            }
          },
          {
            "@type": "Question",
            "name": "Blijft er kans op lekkage bestaan ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Als het dak goed is hersteld, is de kans op lekkage klein. Slechte afwerking vergroot juist het risico."
            }
          },
          {
            "@type": "Question",
            "name": "Moet het binnendeel worden afgesloten ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Vaak wel, om tocht en vochtproblemen te voorkomen. Hoe dit gebeurt, hangt af van de situatie."
            }
          },
          {
            "@type": "Question",
            "name": "Is deze oplossing altijd goedkoper ▾",
            "acceptedAnswer": {
              "@type": "Answer",
