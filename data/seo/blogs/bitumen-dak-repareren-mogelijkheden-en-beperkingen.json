            "@type": "Question",
            "name": "Hoe lang gaat een gerepareerd dak mee ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat verschilt per situatie. Soms jaren, soms slechts tijdelijk, afhankelijk van de staat van het dak als geheel."
            }
          },
          {
            "@type": "Question",
            "name": "Waarom mislukt een reparatie soms ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Omdat de echte oorzaak niet op de gerepareerde plek zat, maar ergens anders in het dak."
            }
          },
          {
            "@type": "Question",
            "name": "Kan ik meerdere keren blijven repareren ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Tot op zekere hoogte wel, maar elk dak bereikt een punt waarop verdere reparaties weinig zin meer hebben."
            }
