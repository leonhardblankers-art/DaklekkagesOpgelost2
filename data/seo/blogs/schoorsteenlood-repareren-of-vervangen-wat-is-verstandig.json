        "mainEntity": [
          {
            "@type": "Question",
            "name": "Is repareren goedkoper dan vervangen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Op korte termijn vaak wel, maar bij herhaalde schade kan vervangen uiteindelijk voordeliger zijn."
            }
          },
          {
            "@type": "Question",
            "name": "Hoe lang blijft een reparatie doorgaans betrouwbaar ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat hangt af van de staat van het lood. Bij beginnende schade kan een reparatie enkele jaren standhouden, bij verouderd lood vaak veel korter."
            }
          },
          {
            "@type": "Question",
            "name": "Moet altijd het volledige lood worden vervangen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet altijd. Soms is gedeeltelijke vervanging mogelijk, mits de rest van het lood nog in goede staat is."
            }
          },
          {
            "@type": "Question",
            "name": "Kan repareren lekkage volledig uitsluiten ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Reparatie kan lekkage verminderen of tijdelijk stoppen, maar biedt geen garantie wanneer het lood zijn flexibiliteit heeft verloren."
