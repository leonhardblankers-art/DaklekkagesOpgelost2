        },
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Wanneer is een daklekkage ‘terugkerend’ ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Een lekkage is terugkerend als het probleem na een eerdere reparatie opnieuw optreedt, tijdelijk verdwijnt of zich later op een andere plek manifesteert."
            }
          },
          {
            "@type": "Question",
            "name": "Waarom komt een daklekkage terug nadat hij gerepareerd lijkt ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Vaak is de oorzaak niet goed vastgesteld of is alleen het zichtbare gevolg hersteld, terwijl water via een andere route opnieuw schade veroorzaakt."
            }
          },
          {
            "@type": "Question",
            "name": "Kan een lekkage zichtbaar worden op een andere plek dan waar het water binnenkomt ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Water kan zich via isolatie, hout en overlappende lagen verplaatsen en pas zichtbaar worden op de plek waar het tegen weerstand aanloopt."
            }
          },
          {
            "@type": "Question",
            "name": "Kunnen oude dakreparaties nieuwe lekkages veroorzaken ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Oude noodreparaties, extra lagen of ongeschikte materialen kunnen de waterafvoer en dakopbouw verstoren, waardoor later nieuwe zwakke plekken ontstaan."
            }
          },
          {
            "@type": "Question",
            "name": "Wanneer is een daklekkage geen lokaal probleem ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Als de lekkage samenhangt met het dakvlak, de afwatering, het afschot of meerdere aansluitingen, is plaatselijk herstel meestal niet voldoende en blijft het probleem terugkomen."
            }
          },
          {
            "@type": "Question",
            "name": "Wat is de beste eerste stap voor een blijvende oplossing ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Een grondige analyse van het dak als geheel is essentieel, zodat waterloop, detaillering en eerdere ingrepen kunnen worden beoordeeld voordat er opnieuw wordt gerepareerd."
            }
          }
        ]
