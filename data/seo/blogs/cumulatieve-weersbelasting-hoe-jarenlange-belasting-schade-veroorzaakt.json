        "mainEntity": [
          {
            "@type": "Question",
            "name": "Kan goed onderhoud de levensduur onbeperkt verlengen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. Onderhoud vertraagt veroudering en beperkt schade, maar ieder dak bereikt uiteindelijk zijn technische grens."
            }
          },
          {
            "@type": "Question",
            "name": "Hoe vaak moet een dak worden gecontroleerd ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat hangt af van type dak, ligging en ouderdom. Oudere daken en daken met eerdere reparaties vragen doorgaans om vaker toezicht."
            }
          },
          {
            "@type": "Question",
            "name": "Is onderhoud ook zinvol zonder klachten ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Juist dan. Veel schade ontwikkelt zich zonder directe zichtbare signalen."
            }
          },
          {
            "@type": "Question",
            "name": "Kan achterstallig onderhoud worden ingehaald ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Soms wel, maar niet altijd volledig. De mate van schade en duur van achterstand zijn bepalend."
            }
          },
          {
            "@type": "Question",
            "name": "Heeft onderhoud invloed op onverwachte lekkages ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Regelmatige controle verkleint de kans dat verborgen gebreken plots tot lekkage leiden."
