        "mainEntity": [
          {
            "@type": "Question",
            "name": "Hoe herken ik versleten voegwerk bij mijn schoorsteen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Versleten voegwerk is vaak te herkennen aan scheuren, uitspoeling, loszittende delen of voegen die poederachtig aanvoelen."
            }
          },
          {
            "@type": "Question",
            "name": "Kan slecht voegwerk een daklekkage veroorzaken ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja, via open of verzwakte voegen kan regenwater de schoorsteen binnendringen en zich verspreiden in het dak of de woning."
            }
          },
          {
            "@type": "Question",
            "name": "Is opnieuw voegen altijd nodig bij schade ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet altijd. Bij beperkte slijtage kan plaatselijk herstel voldoende zijn. Bij grootschalige veroudering is vervangen duurzamer."
            }
          },
          {
            "@type": "Question",
            "name": "Wat is het verschil tussen kalkmortel en moderne mortel ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Kalkmortel is zachter en ademend, moderne mortel is harder en vaak waterafstotender. De juiste keuze hangt af van de schoorsteen."
            }
          },
          {
            "@type": "Question",
            "name": "Hoe lang gaat nieuw voegwerk mee ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Goed aangebracht voegwerk kan tientallen jaren meegaan, afhankelijk van materiaalkeuze en blootstelling aan weer en wind."
            }
          }
