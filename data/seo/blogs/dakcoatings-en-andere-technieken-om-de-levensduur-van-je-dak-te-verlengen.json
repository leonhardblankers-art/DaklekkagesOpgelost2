          },
          {
            "@type": "Question",
            "name": "Is een coating goedkoper dan dakvervanging ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Op korte termijn meestal wel, maar het is geen vervanging van structureel herstel of vernieuwing."
            }
          },
          {
            "@type": "Question",
            "name": "Kan elke dakbedekking gecoat worden ▾",
            "acceptedAnswer": {
              "@type": "Answer",
