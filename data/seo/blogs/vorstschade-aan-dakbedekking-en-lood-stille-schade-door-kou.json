        "mainEntity": [
          {
            "@type": "Question",
            "name": "Ontstaat vorstschade alleen bij extreme kou ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. Juist herhaalde lichte vorst kan op termijn meer schade veroorzaken dan korte perioden van strenge kou."
            }
          },
          {
            "@type": "Question",
            "name": "Is vorstschade altijd zichtbaar ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. Veel schade blijft verborgen totdat water de zwakke plek bereikt."
            }
          },
          {
            "@type": "Question",
            "name": "Zijn alle dakmaterialen even gevoelig voor vorst ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. Sommige materialen verliezen sneller hun flexibiliteit dan andere en reageren sterker op temperatuurwisselingen."
            }
          },
          {
            "@type": "Question",
            "name": "Kan vorstschade vanzelf herstellen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. Materiaalveroudering door kou is blijvend en herstelt zich niet vanzelf."
            }
          }
