        "mainEntity": [
          {
            "@type": "Question",
            "name": "Hoe herken ik dat een lekkage geen lokaal probleem is ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Als een lekkage blijft terugkomen, zich verplaatst of niet reageert op lokale reparaties, is de kans groot dat de oorzaak breder ligt dan één plek."
            }
          },
          {
            "@type": "Question",
            "name": "Kan slechte afwatering lekkage op afstand veroorzaken ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Verstoorde afwatering kan water ophopen en via het dakvlak naar andere delen van het dak leiden."
            }
          },
          {
            "@type": "Question",
            "name": "Zijn niet-lokale lekkages moeilijker op te lossen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ze vragen om een bredere aanpak, maar zijn goed op te lossen zodra de volledige oorzaak in beeld is gebracht."
            }
          },
          {
            "@type": "Question",
            "name": "Heeft constructieve beweging invloed op lekkages ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Beweging door temperatuurverschillen of belasting kan openingen veroorzaken waar water binnendringt."
            }
          },
          {
            "@type": "Question",
            "name": "Is een dakinspectie altijd nodig bij niet-lokale lekkage ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet altijd, maar vaak wel om structurele problemen uit te sluiten of vast te stellen."
            }
          }
        ]
