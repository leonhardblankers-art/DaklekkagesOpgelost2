        "mainEntity": [
          {
            "@type": "Question",
            "name": "Hoe snel ontstaat verborgen waterschade na een daklekkage ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat verschilt per situatie. Bij langdurige lekkage kan schade binnen enkele weken ontstaan, terwijl kleine lekkages pas na maanden duidelijke gevolgen laten zien."
            }
          },
          {
            "@type": "Question",
            "name": "Is een droge plek voldoende bewijs dat er geen schade meer is ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. Ook als een plek droog lijkt, kan er nog vocht aanwezig zijn in isolatie of hout. Visuele controle alleen geeft geen volledig beeld."
            }
          },
          {
            "@type": "Question",
            "name": "Kan waterschade vanzelf opdrogen zonder gevolgen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "In sommige gevallen droogt oppervlakkig vocht op, maar ingesloten materialen zoals isolatie drogen nauwelijks. De kans op blijvende schade blijft dan aanwezig."
            }
          },
          {
            "@type": "Question",
            "name": "Hoe herken je houtrot door daklekkage ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Houtrot ontstaat geleidelijk en uit zich in verkleuring, verzachting van het hout en soms een muffe geur. Het is vaak pas zichtbaar in een vergevorderd stadium."
            }
          },
          {
            "@type": "Question",
            "name": "Heeft elke daklekkage verborgen schade tot gevolg ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet altijd. Korte, beperkte lekkages kunnen soms zonder blijvende schade verlopen. De kans neemt toe naarmate de lekkage langer duurt of zich herhaalt."
            }
          }
        ]
