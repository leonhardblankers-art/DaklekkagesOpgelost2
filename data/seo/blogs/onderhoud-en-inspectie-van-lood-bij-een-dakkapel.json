        "mainEntity": [
          {
            "@type": "Question",
            "name": "Hoe vaak moet lood bij een dakkapel worden gecontroleerd ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Bij oudere dakkapellen is een periodieke visuele controle verstandig, bijvoorbeeld in combinatie met ander dakonderhoud."
            }
          },
          {
            "@type": "Question",
            "name": "Kan onderhoud de levensduur van lood verlengen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Indirect wel. Door belasting te beperken en problemen vroeg te signaleren, blijft het lood langer functioneel."
            }
          },
          {
            "@type": "Question",
            "name": "Is onderhoud voldoende om lekkage te voorkomen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet altijd. Veroudering stopt niet, maar onderhoud helpt om verrassingen te voorkomen."
            }
          },
          {
            "@type": "Question",
            "name": "Moet inspectie altijd van dichtbij gebeuren ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet per se. Een eerste beoordeling kan vaak op afstand, maar bij twijfel is een nadere inspectie nodig."
            }
          }
