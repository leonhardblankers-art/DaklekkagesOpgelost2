          "mainEntity": [
            {
              "@type": "Question",
              "name": "Wat veroorzaakt verzakking van een dakvlak?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Verzakking ontstaat meestal door constructieve verzwakking, langdurige vochtbelasting, houtrot of overbelasting van het dak. Ook veroudering van materialen kan een rol spelen."
              }
            },
            {
              "@type": "Question",
              "name": "Waarom is een verstoorde waterafvoer schadelijk voor het dak?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Wanneer water niet goed kan aflopen, ontstaat stilstaand water. Dit versnelt slijtage van dakbedekking, verhoogt de kans op lekkages en vergroot het risico op verdere constructieve schade."
              }
            },
            {
              "@type": "Question",
              "name": "Wanneer is ingrijpen bij verzakking noodzakelijk?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Als er zichtbaar hoogteverschil, plasvorming of terugkerende lekkages optreden, is inspectie noodzakelijk. Tijdig ingrijpen voorkomt grotere schade en mogelijk kostbare dakrenovatie."
              }
            }
          ]
