        },
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Zijn biobased materialen altijd duurzamer ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet per definitie. Ze hebben vaak een lagere milieubelasting, maar moeten wel geschikt zijn voor de dakopbouw."
            }
          },
          {
            "@type": "Question",
            "name": "Welk isolatiemateriaal kan het beste tegen vocht ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Materialen met vochtbufferende eigenschappen, zoals houtvezel of cellulose, kunnen beter omgaan met tijdelijke vochtbelasting."
            }
          },
          {
            "@type": "Question",
            "name": "Is een hoge isolatiewaarde altijd beter ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet altijd. Een hoge isolatiewaarde helpt, maar zegt niets over vochtgedrag of levensduur."
            }
          },
          {
            "@type": "Question",
            "name": "Kunnen isolatiematerialen worden gerecycled ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat verschilt per materiaal. Minerale wol en kunststoffen zijn beperkt recyclebaar, biobased materialen meestal eenvoudiger."
            }
          },
          {
            "@type": "Question",
            "name": "Speelt brandveiligheid ook mee ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Sommige materialen zijn onbrandbaar, andere vragen aanvullende maatregelen."
            }
          }
        ]
