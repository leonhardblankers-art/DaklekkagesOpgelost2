        "mainEntity": [
          {
            "@type": "Question",
            "name": "Ontstaan ijsdammen alleen bij veel sneeuw ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. Ook een beperkte hoeveelheid sneeuw kan voldoende zijn wanneer dooi en vorst elkaar afwisselen."
            }
          },
          {
            "@type": "Question",
            "name": "Kunnen ijsdammen vanzelf verdwijnen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Ze smelten wanneer de temperatuur stijgt, maar dat betekent niet dat eventuele schade automatisch verdwijnt."
            }
          },
          {
            "@type": "Question",
            "name": "Zijn ijsdammen altijd zichtbaar vanaf de grond ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet altijd. Ze kunnen zich vormen op plekken die slecht zichtbaar zijn, zoals achter goten of bij opstanden."
            }
          },
          {
            "@type": "Question",
            "name": "Zijn ijsdammen een teken van slecht onderhoud ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet per se. Ze wijzen vaker op een combinatie van weersomstandigheden, isolatie en dakdetails."
            }
          }
        ]
