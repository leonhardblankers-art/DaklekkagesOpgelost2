        "mainEntity": [
          {
            "@type": "Question",
            "name": "Verliest isolatie direct zijn werking als het nat wordt ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja, vrijwel alle isolatiematerialen verliezen een groot deel van hun isolerende werking zodra ze nat zijn, zelfs als dat niet zichtbaar is."
            }
          },
          {
            "@type": "Question",
            "name": "Kan isolatie opnieuw gebruikt worden na een daklekkage ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "In de meeste gevallen niet. Isolatie die langdurig nat is geweest, herstelt zelden volledig en kan problemen blijven veroorzaken."
            }
          },
          {
            "@type": "Question",
            "name": "Is schimmel in isolatie altijd zichtbaar in huis ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. Schimmel kan zich diep in de dakconstructie ontwikkelen zonder dat dit direct zichtbaar is op muren of plafonds."
            }
          },
          {
            "@type": "Question",
            "name": "Maakt het type dak verschil voor isolatieschade ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Bij platte daken blijft vocht vaak langer aanwezig, terwijl bij hellende daken water zich sneller kan verspreiden over grotere oppervlakken."
            }
          },
          {
            "@type": "Question",
            "name": "Kan goede ventilatie isolatieschade voorkomen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ventilatie helpt, maar voorkomt isolatieschade niet wanneer er sprake is van een actieve of langdurige daklekkage."
            }
          }
