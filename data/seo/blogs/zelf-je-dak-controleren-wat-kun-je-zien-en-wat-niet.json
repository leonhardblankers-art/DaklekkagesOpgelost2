        "mainEntity": [
          {
            "@type": "Question",
            "name": "Kun je alle problemen zelf zien ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee, veel problemen zoals houtrot, achtergebleven vocht of lekkages onder dakbedekking zijn niet zichtbaar zonder professioneel onderzoek."
            }
          },
          {
            "@type": "Question",
            "name": "Hoe vaak kun je zelf inspecteren ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Een paar keer per jaar, bijvoorbeeld in het voorjaar en na zware stormen, kan helpen om zichtbare gebreken op te merken. Let ook op seizoensgebonden factoren zoals vallende bladeren of sneeuwbelasting."
            }
          },
          {
            "@type": "Question",
            "name": "Is het veilig om op het dak te klimmen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet altijd. Let op helling en stabiliteit van het dak. Draag geschikte schoenen en gebruik een veilige ladder. Bij twijfel of onveilige omstandigheden schakel een professional in."
            }
          },
          {
            "@type": "Question",
            "name": "Welke hulpmiddelen kunnen helpen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Gebruik een verrekijker om moeilijk bereikbare plekken te bekijken, een vochtmeter voor oppervlakkige vochtmetingen en een camera of drone om foto’s van lastige hoeken te maken."
            }
          }
        ]
