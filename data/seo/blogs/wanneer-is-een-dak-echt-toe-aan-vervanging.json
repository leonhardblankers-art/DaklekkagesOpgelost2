        },
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Hoe weet ik of mijn dak nog goed is ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Let op leeftijd, zichtbare schade, vochtplekken in huis en tekenen van houtrot. Combineer eigen observaties altijd met inspectie."
            }
          },
          {
            "@type": "Question",
            "name": "Kan ik een oud dak blijven repareren ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat kan bij beperkte schade. Wanneer reparaties zich blijven opstapelen, is vervanging vaak duurzamer."
            }
          },
          {
            "@type": "Question",
            "name": "Heeft onderhoud echt zoveel invloed ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Goed onderhoud kan de levensduur aanzienlijk verlengen en onverwachte schade voorkomen."
            }
          },
          {
            "@type": "Question",
            "name": "Verschilt het vervangingsmoment per daktype ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Zeker. Platte daken en hellende daken verouderen op verschillende manieren en in verschillend tempo."
            }
          },
          {
            "@type": "Question",
            "name": "Is een professionele inspectie nodig ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Voor een compleet beeld wel. Verborgen schade blijft zonder vakkennis vaak onopgemerkt."
            }
          }
        ]
