          "mainEntity": [
            {
              "@type": "Question",
              "name": "Hoe kan ik een lekkage op mijn dak herkennen?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Een daklekkage herken je vaak aan vochtplekken op plafonds of muren, schimmelvorming, verkleuring van hout of loslatend stucwerk, vooral na regen."
              }
            },
            {
              "@type": "Question",
              "name": "Kan een kleine scheur in de dakbedekking ernstige schade veroorzaken?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Ja, zelfs kleine scheuren kunnen bij hevige regen of wind leiden tot aanzienlijke waterschade doordat water zich verspreidt binnen de dakconstructie."
              }
            },
            {
              "@type": "Question",
              "name": "Zijn alleen oude daken gevoelig voor lekkages?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Nee, ook nieuwere daken kunnen lekkages ontwikkelen door constructiefouten, slecht aangebrachte aansluitingen of extreme weersinvloeden."
              }
            },
            {
              "@type": "Question",
              "name": "Helpt regelmatig onderhoud tegen daklekkages?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Onderhoud verkleint het risico door afvoeren schoon te houden en schade vroeg te signaleren, maar voorkomt lekkages door constructiefouten niet altijd."
              }
            },
            {
              "@type": "Question",
              "name": "Hoe maak ik onderscheid tussen lekkage en condensatie?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Lekkage door waterinfiltratie hangt vaak samen met regenmomenten, terwijl condensatie meestal ontstaat door ventilatie- en temperatuurproblemen."
              }
