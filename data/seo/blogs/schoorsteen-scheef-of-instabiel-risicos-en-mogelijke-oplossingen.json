            "@type": "Question",
            "name": "Is een scheve schoorsteen altijd gevaarlijk ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee, een scheefstand is niet automatisch gevaarlijk. Het risico hangt af van stabiliteit, scheurvorming en constructieve samenhang."
            }
          },
          {
            "@type": "Question",
            "name": "Kan een schoorsteen schever gaan staan ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja, vooral als de oorzaak actief is, zoals verzakking of verzwakt metselwerk."
            }
          },
          {
            "@type": "Question",
            "name": "Is stabiliseren goedkoper dan renovatie ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Vaak wel, maar alleen als stabiliseren technisch verantwoord is."
            }
          },
          {
            "@type": "Question",
            "name": "Heeft wind invloed op een instabiele schoorsteen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja, windbelasting kan beweging vergroten en schade versnellen."
            }
          },
          {
            "@type": "Question",
            "name": "Kan een scheve schoorsteen lekkages veroorzaken ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Indirect wel, doordat scheuren en aansluitingen open gaan staan."
