          {
            "@type": "Question",
            "name": "Wat zijn de grootste risico’s bij zelf verwijderen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Vallend puin, valgevaar en lekkages door onjuist dakherstel zijn de meest voorkomende risico’s."
            }
          },
          {
            "@type": "Question",
            "name": "Is uitbesteden altijd duurder ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet per definitie. Wanneer fouten en herstelwerk worden meegerekend, kan uitbesteden juist kosten besparen."
            }
          },
          {
            "@type": "Question",
            "name": "Kan ik een deel zelf doen en de rest uitbesteden ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat gebeurt soms, maar vraagt goede afstemming. Vooral het dakherstel laat men vaak uitvoeren door een specialist."
            }
          },
