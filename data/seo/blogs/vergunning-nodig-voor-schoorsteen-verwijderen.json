        "mainEntity": [
          {
            "@type": "Question",
            "name": "Is een vergunning altijd nodig bij schoorsteen verwijderen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee, bij veel reguliere woningen is geen vergunning nodig, vooral bij verwijderen tot dakniveau."
            }
          },
          {
            "@type": "Question",
            "name": "Geldt dit ook voor oudere woningen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Oudere woningen vallen niet automatisch onder monumentenzorg. Alleen bij monumenten of beschermde gezichten gelden strengere regels."
            }
          },
          {
            "@type": "Question",
            "name": "Wat als ik twijfel over de draagconstructie ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dan is het verstandig om dit te laten beoordelen, bijvoorbeeld door een specialist of via de gemeente."
            }
          },
          {
            "@type": "Question",
            "name": "Kan de gemeente achteraf ingrijpen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja, als werkzaamheden niet volgens de regels zijn uitgevoerd, kan de gemeente handhavend optreden."
            }
          },
          {
            "@type": "Question",
            "name": "Waar kan ik dit controleren ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Via het Omgevingsloket of rechtstreeks bij de gemeente kan worden nagegaan of een vergunning of melding nodig is."
            }
          }
        ]
