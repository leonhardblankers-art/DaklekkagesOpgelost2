          "mainEntity": [
            {
              "@type": "Question",
              "name": "Wat veroorzaakt houtrot in een dakconstructie?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Houtrot ontstaat door langdurige vochtbelasting, vaak veroorzaakt door lekkages, condensatie of slechte ventilatie. Wanneer hout langdurig vochtig blijft, krijgen schimmels de kans om het materiaal aan te tasten."
              }
            },
            {
              "@type": "Question",
              "name": "Hoe herken je houtrot in het dak?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Signalen van houtrot zijn verkleuring van het hout, een muffe geur, zacht of brokkelig materiaal en doorbuiging van constructiedelen. In veel gevallen is een professionele inspectie nodig om de ernst vast te stellen."
              }
            },
            {
              "@type": "Question",
              "name": "Is houtrot in een dakconstructie gevaarlijk?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Ja, houtrot vermindert de draagkracht van de dakconstructie. Wanneer dit niet tijdig wordt aangepakt, kan dit leiden tot ernstige constructieve schade en veiligheidsrisico’s."
              }
            }
          ]
