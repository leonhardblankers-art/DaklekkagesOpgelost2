        "mainEntity": [
          {
            "@type": "Question",
            "name": "Ontstaat schimmel altijd door een lekkage ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. Schimmel kan ook ontstaan door condensatie of slechte ventilatie. Bij daklekkages is de schimmel vaak plaatselijk en gekoppeld aan waterschade in de constructie."
            }
          },
          {
            "@type": "Question",
            "name": "Is schimmel na een lekkage gevaarlijk voor de gezondheid ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat hangt af van de hoeveelheid, locatie en blootstelling. Niet elke schimmelplek vormt direct een gezondheidsrisico, maar langdurige aanwezigheid is wel ongewenst."
            }
          },
          {
            "@type": "Question",
            "name": "Kan schimmel vanzelf verdwijnen als het dak droog is ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. Als schimmel eenmaal is ontstaan, verdwijnt deze niet vanzelf. Het stoppen van de lekkage voorkomt verergering, maar bestaande schimmel blijft aanwezig."
            }
          },
          {
            "@type": "Question",
            "name": "Moet isolatie altijd vervangen worden bij schimmel ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet altijd, maar wel vaak. Isolatie die langdurig nat is geweest, vormt een blijvend risico op schimmel en verliest zijn functie."
            }
          },
          {
            "@type": "Question",
            "name": "Hoe weet ik of de schimmel nog actief is ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat is lastig zonder inspectie. Muffe geur, uitbreiding van plekken en blijvend vocht zijn signalen dat het probleem nog actief kan zijn."
            }
          }
        ]
