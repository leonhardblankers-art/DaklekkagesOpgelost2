        "mainEntity": [
          {
            "@type": "Question",
            "name": "Kan condens net zo schadelijk zijn als een lekkage ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Condens kan op termijn schade veroorzaken, maar leidt meestal langzamer tot problemen dan een actieve daklekkage."
            }
          },
          {
            "@type": "Question",
            "name": "Waarom zie ik vochtplekken alleen in de winter ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "In de winter zijn temperatuurverschillen groter en is ventilatie vaak beperkter, wat condensvorming bevordert."
            }
          },
          {
            "@type": "Question",
            "name": "Kan slechte isolatie condens veroorzaken ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Slecht geïsoleerde dakdelen koelen sneller af, waardoor vocht uit de lucht condenseert."
            }
          },
          {
            "@type": "Question",
            "name": "Hoe weet ik zeker wat de oorzaak is ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat is soms lastig zonder inspectie. Het patroon, moment en gedrag van het vocht geven belangrijke aanwijzingen."
            }
          },
          {
            "@type": "Question",
            "name": "Kan een kleine lekkage zich voordoen als condens ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Kleine lekkages kunnen condens versterken en zo een vertekend beeld geven."
            }
          }
        ]
