        "mainEntity": [
          {
            "@type": "Question",
            "name": "Komt lekkage door oud lood vaak voor bij dakkapellen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Vooral bij dakkapellen ouder dan tien tot vijftien jaar is lood een veelvoorkomende oorzaak van lekkage."
            }
          },
          {
            "@type": "Question",
            "name": "Is lekkage altijd zichtbaar aan de binnenkant ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. Water kan langere tijd onzichtbaar wegstromen via de dakconstructie voordat er binnen schade ontstaat."
            }
          },
          {
            "@type": "Question",
            "name": "Heeft het zin om oud lood plaatselijk te repareren ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat kan tijdelijk helpen, maar bij verouderd lood is de kans groot dat nieuwe scheuren ontstaan."
            }
          },
          {
            "@type": "Question",
            "name": "Kan lekkage door lood ook andere problemen veroorzaken ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Denk aan houtrot, aantasting van isolatie en schimmelvorming in de dakkapel."
            }
          }
