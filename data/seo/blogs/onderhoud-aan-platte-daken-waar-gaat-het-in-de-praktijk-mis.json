        "mainEntity": [
          {
            "@type": "Question",
            "name": "Hoe vaak moet een plat dak gecontroleerd worden ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat hangt af van de leeftijd en opbouw van het dak. Bij oudere platte daken of daken met veel details is regelmatige controle belangrijker dan bij nieuwere systemen."
            }
          },
          {
            "@type": "Question",
            "name": "Is stilstaand water altijd een probleem ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet per definitie. Kortdurende waterplassen zijn vaak geen issue. Langdurig stilstaand water vergroot wel de kans op slijtage en lekkages."
            }
          },
          {
            "@type": "Question",
            "name": "Kun je slijtage aan een plat dak altijd zien ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. Veel slijtage ontstaat onder vuil, grind of bij naden en is niet direct zichtbaar zonder gerichte inspectie."
            }
          }
        ]
