            }
          },
          {
            "@type": "Question",
            "name": "Kan een scheur tijdelijk worden gerepareerd ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja, zolang de onderlagen nog droog en stabiel zijn."
            }
          },
          {
            "@type": "Question",
            "name": "Waarom komen scheuren soms steeds terug ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Omdat het bitumen zijn elasticiteit heeft verloren en nieuwe spanningen niet meer kan opvangen."
