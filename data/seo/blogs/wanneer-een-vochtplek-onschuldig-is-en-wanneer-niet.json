        "mainEntity": [
          {
            "@type": "Question",
            "name": "Kan een vochtplek vanzelf verdwijnen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja, vooral bij condens. Maar verdwijnen betekent niet altijd dat de oorzaak weg is. Terugkerende plekken zijn altijd reden om verder te kijken."
            }
          },
          {
            "@type": "Question",
            "name": "Is een gele kring altijd een lekkage ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet altijd, maar het wijst wel op langduriger vocht. Zeker als de kring groeit, is verder onderzoek verstandig."
            }
          },
          {
            "@type": "Question",
            "name": "Moet ik direct het dak laten openmaken ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. In veel gevallen is eerst inspecteren voldoende om te bepalen waar het vocht vandaan komt."
            }
          },
          {
            "@type": "Question",
            "name": "Hoe snel ontstaat gevolgschade ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat verschilt per situatie. Natte isolatie en hout kunnen binnen maanden problemen veroorzaken, soms sneller."
            }
          },
          {
            "@type": "Question",
            "name": "Wat als ik twijfel tussen condens en lekkage ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Als patronen onduidelijk zijn of de plek blijft terugkomen, is controleren verstandiger dan blijven gokken."
            }
          }
