        "mainEntity": [
          {
            "@type": "Question",
            "name": "Kan een lekkende schoorsteen altijd worden hersteld ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet altijd. Als de schoorsteen constructief is aangetast of al meerdere keren is gerepareerd, is herstellen soms geen duurzame oplossing meer."
            }
          },
          {
            "@type": "Question",
            "name": "Is verwijderen definitief beter tegen lekkages ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Verwijderen neemt het risico op lekkage rond de schoorsteen weg, maar het dak moet daarna wel zorgvuldig worden hersteld om nieuwe problemen te voorkomen."
            }
          },
          {
            "@type": "Question",
            "name": "Hoe weet ik waar de lekkage vandaan komt ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat is niet altijd direct zichtbaar. Water kan zich verplaatsen binnen het dak. Een inspectie is vaak nodig om de echte oorzaak vast te stellen."
            }
          },
          {
            "@type": "Question",
            "name": "Speelt de leeftijd van de schoorsteen een rol ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja, oudere schoorstenen hebben vaker last van verouderd metselwerk, voegen en lood, wat de kans op lekkages vergroot."
            }
          },
          {
            "@type": "Question",
            "name": "Kan ik herstellen en later alsnog verwijderen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dat kan, maar het betekent wel dat kosten zich opstapelen. Soms is het verstandiger om direct een structurele keuze te maken."
            }
          }
