        "mainEntity": [
          {
            "@type": "Question",
            "name": "Waarom lekt mijn dak alleen bij harde regen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Bij harde regen spelen winddruk, stuwing en overbelasting van afvoeren een grotere rol. Zwakke plekken worden dan pas zichtbaar."
            }
          },
          {
            "@type": "Question",
            "name": "Kan een dak dat alleen soms lekt toch ernstige schade veroorzaken ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Herhaalde blootstelling aan vocht kan leiden tot natte isolatie, houtrot en schimmel, ook als de lekkage niet continu aanwezig is."
            }
          },
          {
            "@type": "Question",
            "name": "Heeft dit vaker te maken met platte of hellende daken ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Het komt bij beide voor. De oorzaak verschilt: bij platte daken ligt de focus op afvoeren en opstanden, bij hellende daken op pannen en aansluitingen."
            }
          },
          {
            "@type": "Question",
            "name": "Is een regenlekkage moeilijker te vinden ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Vaak wel. Omdat het probleem zich alleen onder specifieke omstandigheden voordoet, is het lastiger om de exacte oorzaak vast te stellen."
            }
          },
          {
            "@type": "Question",
            "name": "Kan onderhoud dit soort lekkages voorkomen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Goed onderhoud verkleint de kans, maar sluit het niet volledig uit. Extreme weersomstandigheden leggen soms ook verborgen constructieve zwaktes bloot."
            }
          }
        ]
