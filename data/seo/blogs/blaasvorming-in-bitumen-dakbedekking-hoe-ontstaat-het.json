          },
          {
            "@type": "Question",
            "name": "Is elke blaas meteen een probleem ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet direct, maar elke blaas vergroot de kans op scheuren en lekkage."
            }
          },
          {
            "@type": "Question",
            "name": "Kan een blaas vanzelf verdwijnen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. De spanning kan tijdelijk afnemen, maar het onderliggende vocht of lucht blijft aanwezig."
            }
          },
          {
            "@type": "Question",
            "name": "Waarom ontstaan blazen vooral in de zomer ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Door warmte zet opgesloten damp uit, waardoor de druk onder de bitumenlaag toeneemt."
            }
          },
          {
            "@type": "Question",
            "name": "Hoe weet ik of er vocht onder een blaas zit ▾",
