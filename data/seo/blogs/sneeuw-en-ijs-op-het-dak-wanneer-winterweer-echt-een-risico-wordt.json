        "mainEntity": [
          {
            "@type": "Question",
            "name": "Is sneeuw op het dak altijd gevaarlijk ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. In veel gevallen vormt sneeuw geen direct risico. Pas wanneer sneeuw lang blijft liggen, nat wordt en opnieuw bevriest, neemt de kans op problemen toe."
            }
          },
          {
            "@type": "Question",
            "name": "Hoe herken je ijsdammen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "IJsdammen ontstaan vaak bij dakranden en zijn zichtbaar als opgestapeld ijs. Binnen kunnen ze leiden tot vochtplekken of lekkage, soms pas na de dooiperiode."
            }
          },
          {
            "@type": "Question",
            "name": "Kan sneeuw schade veroorzaken zonder lekkage ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Extra belasting en herhaald bevriezen en ontdooien kunnen materialen verzwakken zonder dat er direct water binnendringt."
            }
          },
          {
            "@type": "Question",
            "name": "Heeft elk dak evenveel last van sneeuw ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. Isolatie, daktype, hellingshoek en onderhoud bepalen in sterke mate hoe gevoelig een dak is voor sneeuw en ijs."
            }
          }
        ]
