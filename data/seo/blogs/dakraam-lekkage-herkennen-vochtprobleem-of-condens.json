        "mainEntity": [
          {
            "@type": "Question",
            "name": "Kan condens ook schade veroorzaken ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Langdurige condens kan hout aantasten, schimmelvorming veroorzaken en afdichtingen verzwakken. Het is daarom geen onschuldig probleem."
            }
          },
          {
            "@type": "Question",
            "name": "Waarom zie ik vocht, maar alleen af en toe ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Omdat zowel lekkage als condens afhankelijk zijn van omstandigheden. Regen, temperatuur en ventilatie bepalen samen of vocht zichtbaar wordt."
            }
          },
          {
            "@type": "Question",
            "name": "Is schimmel altijd een teken van lekkage ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. Schimmel kan ook ontstaan door condens en onvoldoende ventilatie. Wel wijst het altijd op een structureel vochtprobleem."
            }
          },
          {
            "@type": "Question",
            "name": "Helpt ventileren bij lekkage ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ventileren helpt bij condens, maar lost een lekkage van buitenaf niet op. Het kan wel tijdelijk de zichtbare klachten verminderen."
            }
          }
        ]
