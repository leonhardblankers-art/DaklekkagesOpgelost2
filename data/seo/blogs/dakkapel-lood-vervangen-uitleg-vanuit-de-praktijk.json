        "mainEntity": [
          {
            "@type": "Question",
            "name": "Hoe lang gaat lood bij een dakkapel gemiddeld mee ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Bij correcte plaatsing kan lood twintig tot dertig jaar meegaan. De daadwerkelijke levensduur hangt af van belasting door weer, dakvorm en montagekwaliteit."
            }
          },
          {
            "@type": "Question",
            "name": "Is lekkage altijd direct zichtbaar bij slecht lood ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. Water kan langere tijd via constructiedelen wegstromen voordat er binnenshuis schade zichtbaar wordt."
            }
          },
          {
            "@type": "Question",
            "name": "Kan ik lood zelf vervangen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Het technisch uitvoeren lijkt soms eenvoudig, maar fouten in aansluiting of bevestiging leiden vaak tot nieuwe lekkages. Ervaring is hierbij bepalend."
            }
          },
          {
            "@type": "Question",
            "name": "Zijn loodvervangers altijd beter dan traditioneel lood ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet altijd. In sommige situaties werken alternatieven goed, in andere gevallen biedt traditioneel lood meer zekerheid."
            }
          }
