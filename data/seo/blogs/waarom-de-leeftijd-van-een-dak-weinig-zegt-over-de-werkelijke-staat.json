        "mainEntity": [
          {
            "@type": "Question",
            "name": "Is een dak van dertig jaar automatisch aan vervanging toe ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. Sommige daken functioneren technisch nog goed na dertig jaar, terwijl andere eerder problemen vertonen."
            }
          },
          {
            "@type": "Question",
            "name": "Waarom wordt leeftijd zo vaak gebruikt als criterium ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Omdat het eenvoudig en tastbaar is, terwijl technische conditie lastiger te beoordelen lijkt."
            }
          },
          {
            "@type": "Question",
            "name": "Kan een jong dak toch verborgen schade hebben ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Uitvoeringsfouten of zware belasting kunnen al vroeg problemen veroorzaken."
            }
          },
          {
            "@type": "Question",
            "name": "Hoe bepaal je de werkelijke staat van een dak ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Door te kijken naar materiaalconditie, schadepatronen, onderhoud en belasting, niet alleen naar leeftijd."
            }
          },
          {
            "@type": "Question",
            "name": "Heeft leeftijd dan helemaal geen waarde ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Leeftijd heeft waarde als context, maar mag nooit het enige besliscriterium zijn."
            }
          }
        ]
