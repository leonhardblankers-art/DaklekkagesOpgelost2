        "mainEntity": [
          {
            "@type": "Question",
            "name": "Hoe kan een daklekkage op een andere plek terugkomen ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Water kan zich binnen een dakconstructie verplaatsen via isolatie, hout en overlappende daklagen. Daardoor wordt de schade zichtbaar op een andere plek dan waar het water het dak binnenkomt."
            }
          },
          {
            "@type": "Question",
            "name": "Betekent een verplaatsende lekkage dat de vorige reparatie fout was ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet altijd fout uitgevoerd, maar vaak wel gebaseerd op een verkeerde diagnose. De zichtbare schade is hersteld, terwijl de daadwerkelijke oorzaak is blijven bestaan."
            }
          },
          {
            "@type": "Question",
            "name": "Kunnen weersomstandigheden invloed hebben op verplaatsende lekkages ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Wind, langdurige regen of smeltwater zorgen voor een andere waterbelasting, waardoor water nieuwe routes kan volgen binnen het dak."
            }
          },
          {
            "@type": "Question",
            "name": "Is een lokale reparatie voldoende bij een verplaatsende lekkage ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "In de meeste gevallen niet. Zolang de waterloop en onderliggende oorzaak niet worden aangepakt, blijft de lekkage zich herhalen."
            }
          },
          {
            "@type": "Question",
            "name": "Hoe wordt de oorzaak van een verplaatsende lekkage vastgesteld ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dit vraagt om gericht lekkageonderzoek en beoordeling van het volledige dak, waarbij waterloop, dakdetails en eerdere reparaties worden meegenomen."
            }
          }
        ]
