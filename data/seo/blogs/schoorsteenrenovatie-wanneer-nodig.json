        "mainEntity": [
          {
            "@type": "Question",
            "name": "Hoe vaak moet een schoorsteen geïnspecteerd worden ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Een jaarlijkse visuele controle is meestal voldoende. Bij oudere schoorstenen kan een diepgaande inspectie om de 5 tot 10 jaar nuttig zijn."
            }
          },
          {
            "@type": "Question",
            "name": "Kan ik zelf mijn schoorsteen inspecteren ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Een visuele inspectie vanaf zolder of dak kan eerste tekenen van schade laten zien, maar een vakman is nodig voor een grondige beoordeling."
            }
          },
          {
            "@type": "Question",
            "name": "Wat kost schoorsteenrenovatie gemiddeld ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "De kosten hangen af van de staat van de schoorsteen en materialen. Kleine herstelwerkzaamheden zijn goedkoper dan een volledige vervanging van de voering."
            }
          },
          {
            "@type": "Question",
            "name": "Is een nieuwe voering altijd nodig ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet altijd. Soms volstaat herstel van voegwerk of stenen. Een nieuwe voering is nodig bij beschadigde binnenpijpen."
            }
          },
          {
            "@type": "Question",
            "name": "Hoe lang gaat een gerenoveerde schoorsteen mee ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Met goed onderhoud kan een gerenoveerde schoorsteen tientallen jaren meegaan, afhankelijk van materialen en kwaliteit van het werk."
            }
          }
        ]
