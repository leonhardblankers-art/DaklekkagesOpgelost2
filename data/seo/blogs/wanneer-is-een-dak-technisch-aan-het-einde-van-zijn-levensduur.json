        "mainEntity": [
          {
            "@type": "Question",
            "name": "Kan een dak zonder lekkage technisch zijn einde bereiken ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Functieverlies kan aanwezig zijn zonder directe lekkage, doordat schade zich eerst intern ontwikkelt."
            }
          },
          {
            "@type": "Question",
            "name": "Is het technische einde altijd zichtbaar ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nee. Veel signalen zijn subtiel en worden pas duidelijk bij gerichte inspectie."
            }
          },
          {
            "@type": "Question",
            "name": "Betekent het technische einde dat vervanging noodzakelijk is ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Niet per definitie. Soms is tijdelijk functioneren mogelijk, maar de risico’s nemen toe."
            }
          },
          {
            "@type": "Question",
            "name": "Hoe verhoudt onderhoud zich tot het technische einde ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Onderhoud kan het moment uitstellen, maar niet onbeperkt. Uiteindelijk bereikt ieder dak zijn technische grens."
            }
          },
          {
            "@type": "Question",
            "name": "Kunnen dakdetails eerder falen dan het dakoppervlak ▾",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Aansluitingen en details vormen vaak de eerste zwakke schakels."
            }
          }
